# Keeper Bot — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before deploying.
# NEVER commit .env to git — it is listed in .gitignore.
# In production (Render), set these as environment variables in the dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# Solana RPC — get a free key at helius.dev
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Solana keypairs — JSON arrays (64 bytes each) from `solana-keygen new`
# Generate: solana-keygen new --outfile admin.json  → then cat admin.json
ADMIN_KEYPAIR=[1,2,3,...,64]
MANAGER_KEYPAIR=[1,2,3,...,64]

# On-chain addresses — populated after running vault-setup scripts 01–07
VAULT_ADDRESS=
KAMINO_STRATEGY_ADDRESS=
TRUSTFUL_STRATEGY_ADDRESS=

# Standard Solana token addresses (safe as-is for mainnet)
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
HL_API_URL=https://api.hyperliquid.xyz
OSPREY_API_URL=https://osprey-three.vercel.app

# Hyperliquid EVM wallet — used for signing orders server-side
# Generate a fresh wallet: npx ethers repl → ethers.Wallet.createRandom()
HL_PRIVATE_KEY=0x...
HL_WALLET_ADDRESS=0x...

# Postgres database — create a free project at supabase.com
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Adaptor program IDs — VERIFY from primary sources before deploying
# Source: https://docs.ranger.finance/security/deployed-programs
KAMINO_ADAPTOR_PROGRAM_ID=
TRUSTFUL_ADAPTOR_PROGRAM_ID=

# Kamino pool counterparty token accounts — VERIFY from:
# https://github.com/voltrxyz/kamino-scripts (README)
KAMINO_COUNTER_PARTY_TA=
KAMINO_COUNTER_PARTY_TA_AUTH=
KAMINO_PROTOCOL_PROGRAM=
